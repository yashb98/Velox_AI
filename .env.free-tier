# ============================================================================
# VELOX AI - FREE TIER CONFIGURATION
# ============================================================================
# This configuration uses free-tier services for development and testing.
# Copy this file to .env and fill in your API keys.
#
# FREE TIER SERVICES SETUP:
#
# 1. PostgreSQL (Neon - Free):
#    - Sign up: https://neon.tech
#    - Create a project, copy the connection string
#    - Free tier: 0.5 GB storage, 1 project
#
# 2. Redis (Upstash - Free):
#    - Sign up: https://upstash.com
#    - Create a Redis database, copy credentials
#    - Free tier: 10,000 commands/day
#
# 3. Kimi/Moonshot AI (Your paid key):
#    - Platform: https://platform.moonshot.cn
#    - Models: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
#
# 4. Deepgram (Free credits):
#    - Sign up: https://deepgram.com
#    - New accounts get $200 in free credits
#
# ============================================================================

# ── Core Settings ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ── Database (Neon Free Tier) ───────────────────────────────────────────────
# Get your connection string from: https://console.neon.tech
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL=postgresql://your-user:your-password@your-project.neon.tech/velox?sslmode=require

# ── Redis (Upstash Free Tier) ───────────────────────────────────────────────
# Get your credentials from: https://console.upstash.com
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379
REDIS_HOST=your-endpoint.upstash.io
REDIS_PORT=6379

# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: kimi, gemini, openai
# Set to "kimi" to use your Moonshot AI key
LLM_PROVIDER=kimi

# ── Kimi / Moonshot AI (Your paid key) ──────────────────────────────────────
# Get your API key from: https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=your-kimi-api-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
# Models: moonshot-v1-8k (cheapest), moonshot-v1-32k, moonshot-v1-128k
KIMI_MODEL=moonshot-v1-8k

# Alternative: If using international endpoint
# KIMI_BASE_URL=https://api.moonshot.ai/v1

# ── Authentication (Disabled for development) ──────────────────────────────
# Set to "true" when you want to enable Clerk authentication
CLERK_ENABLED=false
DEV_USER_ID=dev-user-001
DEV_ORG_ID=dev-org-001

# ── Speech-to-Text (Deepgram - Free credits) ────────────────────────────────
# Sign up at: https://deepgram.com (New accounts get $200 free credits)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Text-to-Speech (Optional - Deepgram TTS) ────────────────────────────────
# Deepgram also provides TTS, included in your credits
# Or leave blank to use a simple TTS fallback

# ── Twilio (Optional - Trial account) ───────────────────────────────────────
# Sign up at: https://twilio.com ($15 trial credit)
# Leave blank if not testing phone calls
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_PHONE_NUMBER=

# ── Stripe (Free until you charge) ──────────────────────────────────────────
# Sign up at: https://stripe.com
# Use test mode keys for development
STRIPE_SECRET_KEY=sk_test_your_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Frontend URLs ───────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:5173
VITE_API_URL=http://localhost:8080

# ── Observability (Optional) ───────────────────────────────────────────────
# LangFuse - Free tier available at: https://langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Admin ───────────────────────────────────────────────────────────────────
ADMIN_API_KEY=dev-admin-key-change-me

# ============================================================================
# COST BREAKDOWN (Monthly estimates for light usage):
#
# Neon PostgreSQL:     $0 (free tier)
# Upstash Redis:       $0 (free tier - 10K commands/day)
# Kimi API:            ~$5-20 (depends on usage)
# Deepgram:            $0 (free credits, then ~$0.0043/min)
# Twilio:              $0 (trial) or ~$15/mo minimum
# Stripe:              $0 (only charges on transactions)
# Clerk:               $0 (disabled)
#
# Total estimated:     $5-35/month for development
# ============================================================================
